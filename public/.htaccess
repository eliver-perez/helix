RewriteEngine On

# Si existe archivo o carpeta, servir normal
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# API
RewriteRule ^api(/.*)?$ api.php [QSA,L]

# /staff, /staff/add, /staff/123, /staff/123/edit
RewriteRule ^([^/]+)(/.*)?$ $1/index.php [QSA,L]

# Quitar slash final
RewriteCond %{REQUEST_URI} .+/$
RewriteRule ^(.+)/$ /$1 [R=301,L]

ErrorDocument 404 /helix/public/404.html